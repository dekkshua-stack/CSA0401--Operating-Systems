#include <stdio.h>
#include <semaphore.h>
int main()
{
    int n, i;
    sem_t mutex, empty, full;
    sem_init(&mutex, 0, 1);
    sem_init(&empty, 0, 5);
    sem_init(&full, 0, 0);
    printf("Enter the number of items to produce: ");
    scanf("%d", &n);
    for(i = 1; i <= n; i++)
    {
        sem_wait(&empty);
        sem_wait(&mutex);
        printf("Producer produced item %d\n", i);
        sem_post(&mutex);
        sem_post(&full);
        sem_wait(&full);
        sem_wait(&mutex);
        printf("Consumer consumed item %d\n", i);
        sem_post(&mutex);
        sem_post(&empty);
    }
    sem_destroy(&mutex);
    sem_destroy(&empty);
    sem_destroy(&full);
    return 0;
}

INPUT :

Enter the number of items to produce: 5

OUTPUT :

Producer produced item 1
Consumer consumed item 1
Producer produced item 2
Consumer consumed item 2
Producer produced item 3
Consumer consumed item 3
Producer produced item 4
Consumer consumed item 4
Producer produced item 5
Consumer consumed item 5
